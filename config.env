# termux folder (uncomment if you are using proot-distro)
# export PREFIX=/data/data/com.termux/files/usr

# Default disk size updated to 20G
export DISK_SIZE=${DISK_SIZE:-20G}

# Alpine password
export ROOT_PASSWORD=${ROOT_PASSWORD:-Secret123}

# Default resources: 1GB RAM to prevent Android LMK, 6 CPUs
export QEMU_RAM=${QEMU_RAM:-1024}
export QEMU_CPUS=${QEMU_CPUS:-6}

# Alpine iso for virtual machines
export ALPINE_ISO_URL=${ALPINE_ISO_URL:-http://dl-cdn.alpinelinux.org/alpine/v3.19/releases/aarch64/alpine-virt-3.19.0-aarch64.iso}